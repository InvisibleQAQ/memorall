{
  "private": true,
  "name": "memorall",
  "description": "Memorall - AI-powered memory and knowledge management browser extension built with Extension.js, TypeScript, and React.",
  "version": "0.2.17",
  "license": "MIT",
  "type": "module",
  "homepage": "https://zrg-team.github.io/memorall",
  "author": {
    "name": "Zergling",
    "email": "zerglingno2@outlook.com"
  },
  "scripts": {
    "postinstall": "patch-package",
    "predev": "node tools/build-manifest.mjs && node tools/copy-bundled-assets.mjs && node tools/generate-transformer-runner-configs.mjs && node tools/prepare-dev.mjs",
    "dev": "dotenv -e .env -- cross-env-shell \"extension dev --chromium-binary $CHROME_PATH\"",
    "start": "extension start",
    "extension:dev": "extension dev",
    "prebuild": "node tools/build-manifest.mjs && node tools/copy-bundled-assets.mjs && node tools/generate-transformer-runner-configs.mjs",
    "build": "extension build",
    "preview": "extension preview",
    "watch": "extension dev --watch",
    "build:prod": "node tools/build-manifest.mjs && cross-env NODE_ENV=production extension build && node tools/prepare-production.mjs",
    "build:chrome": "node tools/build-manifest.mjs && extension build --target=chrome-mv3",
    "build:edge": "node tools/build-manifest.mjs && extension build --target=edge-mv3",
    "build:firefox": "node tools/build-manifest.mjs && extension build --target=firefox-mv3",
    "build:all": "npm run build:chrome && npm run build:edge && npm run build:firefox",
    "package:chrome": "cd dist/chrome && tar -a -c -f ../../memorall-chrome.zip *",
    "package:edge": "cd dist/chrome && tar -a -c -f ../../memorall-edge.zip *",
    "package:all": "npm run build:prod && npm run package:chrome && npm run package:edge",
    "package": "node tools/build-manifest.mjs && node ./tools/build-publish.mjs",
    "build:landing_page": "node tools/deploy-runner.mjs",
    "type-check": "tsc --noEmit",
    "clean": "extension clean",
    "lint": "extension lint",
    "format": "npx @biomejs/biome format --write ./src ./scripts",
    "assets:bundled": "node tools/copy-bundled-assets.mjs"
  },
